{
  "name": "vx-web-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "dev": "vite",
    "prebuild": "npm run i18n:check && npm run viewer360:check && npm run help:check",
    "build": "vite build",
    "preview": "vite preview",
    "help:check": "node scripts/check-help-route.cjs",
    "help:i18n-check": "node scripts/check-help-i18n.cjs",
    "viewer360:check": "node scripts/check-viewer360-safety.cjs",
    "viewer360:check-lifecycle": "node scripts/check-viewer360-lifecycle.cjs",
    "routeguide:check": "node scripts/check-routeguide-lifecycle.cjs",
    "i18n:check": "node scripts/check-i18n-keys.cjs",
    "translate:locales": "node scripts/translate.cjs --mode api",
    "translate:locales:todo": "node scripts/translate.cjs --mode api --force-todo",
    "translate:locales:force": "node scripts/translate.cjs --mode api --force",
    "i18n:scan-settings": "node scripts/scan-settings.cjs",
    "i18n:check-settings": "node scripts/validate_json.cjs",
    "i18n:scan-admin": "node scripts/scan-admin.cjs",
    "i18n:check-admin": "node scripts/validate_json.cjs",
    "i18n:scan-map": "node scripts/scan-map.cjs",
    "i18n:check-map": "node scripts/check-map.cjs",
    "i18n:validate-map": "npm run i18n:scan-map && npm run i18n:check-map",
    "i18n:scan-events": "node scripts/scan-events.cjs",
    "i18n:check-events": "node scripts/check-events.cjs",
    "i18n:validate-events": "npm run i18n:scan-events && npm run i18n:check-events",
    "i18n:scan-notifications": "node scripts/scan-notifications.cjs",
    "i18n:check-notifications": "node scripts/check-notifications.cjs",
    "i18n:validate-notifications": "npm run i18n:scan-notifications && npm run i18n:check-notifications",
    "events:validate": "node scripts/validate-events.cjs",
    "events:verify": "node scripts/verify-events-json.cjs",
    "analyze:deps": "depcheck",
    "analyze:graph": "madge --extensions js,vue src",
    "cleanup:check": "npm run build && npm run i18n:check"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.7",
    "three": "^0.184.0",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.4.18",
    "depcheck": "^1.4.7",
    "jsdom": "^29.1.1",
    "madge": "^8.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
